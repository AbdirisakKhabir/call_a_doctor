// Clinic Management System - Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                           Int                  @id @default(autoincrement())
  email                        String               @unique
  password                     String
  name                         String?
  roleId                       Int
  role                         Role                 @relation(fields: [roleId], references: [id], onDelete: Restrict)
  isActive                     Boolean              @default(true)
  purchases                    Purchase[]
  sales                        Sale[]
  appointments                 Appointment[]
  labOrdersCreated             LabOrder[]           @relation("LabOrderCreatedBy")
  labResultsRecorded           LabOrderItem[]       @relation("LabResultRecordedBy")
  prescriptionsCreated         Prescription[]       @relation("PrescriptionCreatedBy")
  expensesCreated              Expense[]            @relation("ExpenseCreatedBy")
  branches                     UserBranch[]
  financeTransactions          AccountTransaction[] @relation("FinanceTransactionCreatedBy")
  internalStockLogs            InternalStockLog[]
  unsellableStockLogsCreated   UnsellableStockLog[] @relation("UnsellableStockLogCreatedBy")
  outreachReturnsCreated       OutreachReturn[]     @relation("OutreachReturnCreatedBy")
  outreachDispensesCreated     OutreachDispense[]   @relation("OutreachDispenseCreatedBy")
  patientPaymentsCreated       PatientPayment[]     @relation("PatientPaymentCreatedBy")
  pharmacySaleReturnsCreated   PharmacySaleReturn[] @relation("PharmacySaleReturnCreatedBy")
  doctorProfile                Doctor?
  visitCardsCreated            DoctorVisitCard[]    @relation("VisitCardCreatedBy")
  auditLogs                    AuditLog[]
  labSalesCreated              LabSale[]            @relation("LabSaleCreatedBy")
  labStockMovementsCreated     LabStockMovement[]   @relation("LabStockMovementCreatedBy")
  customFormsCreated           CustomForm[]         @relation("CustomFormCreatedBy")
  customFormResponsesSubmitted CustomFormResponse[] @relation("CustomFormResponseSubmittedBy")
  staffMembersCreated          StaffMember[]        @relation("StaffMemberCreatedBy")
  /// Last successful password sign-in.
  lastLoginAt                  DateTime?
  /// Last session validation via /api/auth/me (throttled server-side). Used for “active now” in Settings.
  lastSeenAt                   DateTime?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt

  @@index([lastSeenAt])
  @@map("users")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique // e.g. "users.view", "users.create"
  description String?
  module      String? // e.g. "users", "roles", "permissions"
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// Single-row global settings (id = 1).
model AppSettings {
  id                             Int      @id @default(1)
  expirySoonMode                 String   @default("days") // days | months
  expirySoonDays                 Int      @default(10)
  expirySoonMonths               Int      @default(1) // 1 = through end of current month, 2 = through end of next month, etc.
  /// Calendar grid & new-appointment time steps: 15 or 30 minutes.
  appointmentCalendarSlotMinutes Int      @default(15)
  updatedAt                      DateTime @updatedAt

  @@map("app_settings")
}

// Configurable options for "Referred from" on client registration (managed under Settings).
model ReferralSource {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  patients  Patient[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("referral_sources")
}

/// Locality for client address (managed under Settings).
model City {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  villages  Village[]
  patients  Patient[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("cities")
}

model Village {
  id        Int       @id @default(autoincrement())
  cityId    Int
  city      City      @relation(fields: [cityId], references: [id], onDelete: Restrict)
  name      String
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  patients  Patient[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([cityId, name])
  @@map("villages")
}

// --- Patients ---

model Patient {
  id                  Int                  @id @default(autoincrement())
  patientCode         String               @unique
  firstName           String
  lastName            String
  phone               String?
  /// Optional second contact number (e.g. mobile); stored E.164 when set.
  mobile              String?
  email               String?
  dateOfBirth         DateTime?
  /// Full years; recalculated from `dateOfBirth` whenever the client is saved.
  age                 Int?
  gender              String?
  /// Optional street / extra detail; city and village identify locality.
  address             String?
  cityId              Int?
  villageId           Int?
  city                City?                @relation(fields: [cityId], references: [id], onDelete: SetNull)
  village             Village?             @relation(fields: [villageId], references: [id], onDelete: SetNull)
  /// Branch where the client was first registered (required on new registrations).
  registeredBranchId  Int?
  registeredBranch    Branch?              @relation("PatientRegisteredBranch", fields: [registeredBranchId], references: [id], onDelete: SetNull)
  notes               String?
  referralSourceId    Int?
  referralSource      ReferralSource?      @relation(fields: [referralSourceId], references: [id], onDelete: SetNull)
  /// Balance owed by patient (e.g. outreach medication charges).
  accountBalance      Float                @default(0)
  isActive            Boolean              @default(true)
  sales               Sale[]
  appointments        Appointment[]
  patientHistories    PatientHistory[]
  labOrders           LabOrder[]
  prescriptions       Prescription[]
  outreachDispenses   OutreachDispense[]
  patientPayments     PatientPayment[]
  doctorVisitCards    DoctorVisitCard[]
  labSales            LabSale[]
  careFiles           PatientCareFile[]
  customFormResponses CustomFormResponse[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@map("patients")
}

/// A running client file: appointments, lab, notes, prescriptions, and payments can be grouped for a single invoice.
model PatientCareFile {
  id               Int               @id @default(autoincrement())
  patientId        Int
  patient          Patient           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  fileCode         String            @unique
  title            String?
  /// open | closed
  status           String            @default("open")
  openedAt         DateTime          @default(now())
  closedAt         DateTime?
  invoicedAt       DateTime?
  notes            String?
  appointments     Appointment[]
  labOrders        LabOrder[]
  prescriptions    Prescription[]
  patientHistories PatientHistory[]
  doctorVisitCards DoctorVisitCard[]
  patientPayments  PatientPayment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([patientId, status])
  @@map("patient_care_files")
}

// --- Branches ---

model Branch {
  id                  Int                  @id @default(autoincrement())
  name                String
  address             String?
  phone               String?
  email               String?
  isActive            Boolean              @default(true)
  doctors             Doctor[]
  services            Service[]
  appointments        Appointment[]
  users               UserBranch[]
  purchases           Purchase[]
  sales               Sale[]
  internalStockLogs   InternalStockLog[]
  categories          Category[]
  suppliers           Supplier[]
  products            Product[]
  outreachTeams       OutreachTeam[]
  outreachReturns     OutreachReturn[]
  outreachDispenses   OutreachDispense[]
  pharmacySaleReturns PharmacySaleReturn[]
  doctorVisitCards    DoctorVisitCard[]
  patientsRegistered  Patient[]            @relation("PatientRegisteredBranch")
  labInventoryItems   LabInventoryItem[]
  labStockMovements   LabStockMovement[]
  labSales            LabSale[]
  unsellableStockLogs UnsellableStockLog[]
  appointmentScheduleBlocks AppointmentScheduleBlock[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@map("branches")
}

model UserBranch {
  userId   Int
  branchId Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branches")
}

// --- Doctors ---

model Doctor {
  id               Int               @id @default(autoincrement())
  name             String
  email            String?
  phone            String?
  specialty        String?
  branchId         Int?
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  isActive         Boolean           @default(true)
  appointments     Appointment[]
  patientHistories PatientHistory[]
  labOrders        LabOrder[]
  prescriptions    Prescription[]
  userId           Int?              @unique
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  doctorVisitCards DoctorVisitCard[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("doctors")
}

// --- Services ---

model Service {
  id                  Int                  @id @default(autoincrement())
  name                String
  /// Calendar / appointment UI: hex e.g. #dbeafe; null = use default styling
  color               String?
  description         String?
  price               Float                @default(0)
  durationMinutes     Int? // e.g. 30, 60
  branchId            Int?
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  isActive            Boolean              @default(true)
  appointmentServices AppointmentService[]
  disposables         ServiceDisposable[]
  saleItems           SaleItem[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@map("services")
}

/// Pharmacy product (by code at appointment branch) consumed when a booked service is completed.
model ServiceDisposable {
  id               Int      @id @default(autoincrement())
  serviceId        Int
  service          Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  /// Matches `Product.code` at the appointment branch.
  productCode      String
  /// Consumption per one service line quantity step, in `deductionUnitKey` (see ProductSaleUnit).
  unitsPerService  Float    @default(1)
  deductionUnitKey String   @default("base")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([serviceId, productCode])
  @@index([serviceId])
  @@map("service_disposables")
}

/// Holidays and blocked hours — bookings cannot be created or moved into these windows (per branch or all branches).
model AppointmentScheduleBlock {
  id        Int       @id @default(autoincrement())
  branchId  Int?
  branch    Branch?   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  allDay    Boolean   @default(true)
  label     String?
  isActive  Boolean   @default(true)
  windows   AppointmentScheduleBlockWindow[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([startDate, endDate])
  @@index([branchId])
  @@map("appointment_schedule_blocks")
}

model AppointmentScheduleBlockWindow {
  id        Int      @id @default(autoincrement())
  blockId   Int
  block     AppointmentScheduleBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  startTime String
  endTime   String
  sortOrder Int      @default(0)

  @@index([blockId])
  @@map("appointment_schedule_block_windows")
}

// --- Appointments ---

model Appointment {
  id                    Int                  @id @default(autoincrement())
  branchId              Int
  branch                Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  doctorId              Int
  doctor                Doctor               @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  patientId             Int
  patient               Patient              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  appointmentDate       DateTime             @db.Date
  startTime             String // e.g. "09:00"
  endTime               String? // e.g. "09:30"
  /// Minutes before start to remind (e.g. 15, 60); null = no reminder
  reminderMinutesBefore Int?
  status                String               @default("scheduled") // scheduled, completed, cancelled, no-show
  notes                 String?
  totalAmount           Float                @default(0)
  /// False when visit billing was posted at booking (immediate sale); delete logic skips reversing an AR bump that never happened.
  postedChargesToPatientOnCreate Boolean               @default(true)
  /// Preferred payment method when completing visit billing (ledger payment method).
  paymentMethodId       Int?
  paymentMethod         LedgerPaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  createdById           Int?
  createdBy             User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  services              AppointmentService[]
  patientHistories      PatientHistory[]
  labOrders             LabOrder[]
  prescriptions         Prescription[]
  careFileId            Int?
  careFile              PatientCareFile?     @relation(fields: [careFileId], references: [id], onDelete: SetNull)
  serviceDisposableLogs InternalStockLog[]
  customFormResponses   CustomFormResponse[]
  sales                 Sale[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([appointmentDate])
  @@index([branchId, appointmentDate])
  @@index([careFileId])
  @@index([paymentMethodId])
  @@map("appointments")
}

model AppointmentService {
  id                    Int         @id @default(autoincrement())
  appointmentId         Int
  appointment           Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId             Int
  service               Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  quantity              Int         @default(1)
  unitPrice             Float
  totalAmount           Float
  /// Set when pharmacy disposables for this line were deducted (idempotent).
  disposablesDeductedAt DateTime?
  createdAt             DateTime    @default(now())

  @@map("appointment_services")
}

/// Reception queue card: patient + doctor + visit date; doctor-linked users only see their cards.
model DoctorVisitCard {
  id                 Int                  @id @default(autoincrement())
  cardNumber         String
  branchId           Int
  branch             Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  patientId          Int
  patient            Patient              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId           Int
  doctor             Doctor               @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  visitDate          DateTime             @db.Date
  status             String               @default("inWaiting") // inWaiting, inProgress, completed, cancelled
  paymentStatus      String               @default("unpaid") // paid, unpaid, appointment, free
  visitFee           Float                @default(0)
  paymentMethodId    Int?
  paymentMethod      LedgerPaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  createdById        Int?
  createdBy          User?                @relation("VisitCardCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  notes              String?
  depositTransaction AccountTransaction?
  careFileId         Int?
  careFile           PatientCareFile?     @relation(fields: [careFileId], references: [id], onDelete: SetNull)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@unique([branchId, cardNumber])
  @@index([careFileId])
  @@index([branchId, visitDate])
  @@index([doctorId, visitDate])
  @@map("doctor_visit_cards")
}

// --- Pharmacy ---

model Category {
  id          Int       @id @default(autoincrement())
  branchId    Int
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  name        String
  description String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([branchId, name])
  @@map("categories")
}

model Supplier {
  id            Int        @id @default(autoincrement())
  branchId      Int
  branch        Branch     @relation(fields: [branchId], references: [id], onDelete: Restrict)
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  isActive      Boolean    @default(true)
  purchases     Purchase[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([branchId])
  @@map("suppliers")
}

model Product {
  id                     Int                     @id @default(autoincrement())
  branchId               Int
  branch                 Branch                  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  name                   String
  code                   String
  description            String?
  imageUrl               String?
  imagePublicId          String?
  costPrice              Float                   @default(0)
  sellingPrice           Float                   @default(0)
  /// Stock on hand in base (smallest) units — see ProductSaleUnit with unitKey "base". Sellable shelf / POS quantity only.
  quantity               Int                     @default(0)
  /// Non-sellable quantity (expired, damaged, etc.) — excluded from POS; see UnsellableStockLog for movements.
  unsellableQuantity     Int                     @default(0)
  /// Label for the base stock unit (e.g. piece, tablet, pair).
  unit                   String                  @default("pcs")
  /// Optional batch / lot expiry (e.g. for medicines).
  expiryDate             DateTime?
  /// When false, item is not sold at POS (lab supplies, cleaning, etc.); stock tracked via purchases, service disposables, and lab transfers.
  forSale                Boolean                 @default(true)
  /// laboratory | cleaning | general — relevant when forSale is false
  internalPurpose        String?
  categoryId             Int?
  category               Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isActive               Boolean                 @default(true)
  purchaseItems          PurchaseItem[]
  saleItems              SaleItem[]             @relation("ProductSaleItems")
  prescriptionItems      PrescriptionItem[]
  internalStockLogs      InternalStockLog[]
  unsellableStockLogs    UnsellableStockLog[]
  outreachInventoryItems OutreachInventoryItem[]
  outreachReturnItems    OutreachReturnItem[]
  outreachDispenseItems  OutreachDispenseItem[]
  saleUnits              ProductSaleUnit[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@unique([branchId, code])
  @@map("products")
}

/// Defines how pharmacy counts stock (base unit) vs purchase/sale packaging (e.g. 1 box = 100 base units).
model ProductSaleUnit {
  id            Int      @id @default(autoincrement())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// Stable key for APIs/POS, e.g. "base", "box". Smallest stock step uses "base" with baseUnitsEach = 1.
  unitKey       String
  /// Display label (e.g. "Piece", "Box").
  label         String
  /// One purchase/sale count of this unit equals this many base units (stock quantity increments/decrements).
  baseUnitsEach Int
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([productId, unitKey])
  @@index([productId])
  @@map("product_sale_units")
}

/// Stock removed for internal operations (lab, cleaning) — not a retail sale.
model InternalStockLog {
  id                   Int          @id @default(autoincrement())
  productId            Int
  product              Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  branchId             Int?
  branch               Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  quantity             Int
  purpose              String
  notes                String?
  /// When usage was triggered by completing an appointment service (reporting).
  relatedAppointmentId Int?
  relatedAppointment   Appointment? @relation(fields: [relatedAppointmentId], references: [id], onDelete: SetNull)
  createdById          Int?
  createdBy            User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt            DateTime     @default(now())

  @@index([productId, createdAt])
  @@index([relatedAppointmentId])
  @@index([purpose, createdAt])
  @@map("internal_stock_logs")
}

/// Movement of stock from sellable quantity to unsellable (expiry, damage, recall, etc.) — inventory write-off from a sales perspective.
model UnsellableStockLog {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  branchId    Int
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  quantity    Int
  reason      String // expired | damaged | recall | other
  notes       String?  @db.Text
  createdById Int?
  createdBy   User?    @relation("UnsellableStockLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([productId])
  @@map("unsellable_stock_logs")
}

model Purchase {
  id                Int                  @id @default(autoincrement())
  branchId          Int?
  branch            Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  /// Optional when stock is received without a vendor record (donation, transfer-in, etc.).
  supplierId        Int?
  supplier          Supplier?            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseDate      DateTime             @default(now())
  totalAmount       Float                @default(0)
  status            String               @default("completed")
  notes             String?
  /// Ledger payment method used to pay the supplier (links to finance account).
  paymentMethodId   Int?
  paymentMethod     LedgerPaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  createdById       Int?
  createdBy         User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items             PurchaseItem[]
  ledgerTransaction AccountTransaction?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@map("purchases")
}

model PurchaseItem {
  id           Int      @id @default(autoincrement())
  purchaseId   Int
  purchase     Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId    Int
  product      Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity     Int
  /// Always pieces (pcs); column kept for schema compatibility.
  purchaseUnit String   @default("pcs")
  unitPrice    Float
  totalAmount  Float
  createdAt    DateTime @default(now())

  @@map("purchase_items")
}

model Sale {
  id                  Int                  @id @default(autoincrement())
  branchId            Int?
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  saleDate            DateTime             @default(now())
  totalAmount         Float                @default(0)
  discount            Float                @default(0)
  paymentMethod       String               @default("cash")
  notes               String?
  patientId           Int?
  patient             Patient?             @relation(fields: [patientId], references: [id], onDelete: SetNull)
  /// walking | patient | outreach
  customerType        String               @default("walking")
  outreachTeamId      Int?
  outreachTeam        OutreachTeam?        @relation(fields: [outreachTeamId], references: [id], onDelete: SetNull)
  /// Stock issued on credit to outreach team (no till deposit; increases team credit balance).
  outreachOnCredit    Boolean              @default(false)
  /// Optional calendar appointment this sale belongs to (visit billing or linked POS).
  appointmentId       Int?
  appointment         Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  /// pos = retail/lab/outreach POS · appointment = visit service lines (no inventory movement)
  kind                String               @default("pos")
  createdById         Int?
  createdBy           User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items               SaleItem[]
  depositTransaction  AccountTransaction?
  pharmacySaleReturns PharmacySaleReturn[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([appointmentId])
  @@map("sales")
}

model SaleItem {
  id                      Int                      @id @default(autoincrement())
  saleId                  Int
  sale                    Sale                     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId               Int?
  product                 Product?                 @relation("ProductSaleItems", fields: [productId], references: [id], onDelete: Restrict)
  /// Set for visit billing lines (kind=appointment); mutually exclusive with productId in application logic.
  serviceId               Int?
  service                 Service?                 @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  quantity                Int
  /// Always pieces (pcs); column kept for schema compatibility.
  saleUnit                String                   @default("pcs")
  unitPrice               Float
  totalAmount             Float
  pharmacySaleReturnItems PharmacySaleReturnItem[]
  createdAt               DateTime                 @default(now())

  @@index([serviceId])
  @@map("sale_items")
}

/// Customer return of retail pharmacy sale lines — restores shelf inventory.
model PharmacySaleReturn {
  id          Int                      @id @default(autoincrement())
  branchId    Int
  branch      Branch                   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  saleId      Int
  sale        Sale                     @relation(fields: [saleId], references: [id], onDelete: Restrict)
  returnDate  DateTime                 @default(now())
  totalAmount Float                    @default(0)
  notes       String?
  createdById Int?
  createdBy   User?                    @relation("PharmacySaleReturnCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items       PharmacySaleReturnItem[]
  createdAt   DateTime                 @default(now())

  @@index([branchId, returnDate])
  @@index([saleId])
  @@map("pharmacy_sale_returns")
}

model PharmacySaleReturnItem {
  id          Int                @id @default(autoincrement())
  returnId    Int
  return      PharmacySaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItemId  Int
  saleItem    SaleItem           @relation(fields: [saleItemId], references: [id], onDelete: Restrict)
  quantity    Int
  unitPrice   Float
  totalAmount Float
  createdAt   DateTime           @default(now())

  @@map("pharmacy_sale_return_items")
}

// --- Outreach (home clinic / emergency medication bag) ---

model OutreachTeam {
  id            Int                     @id @default(autoincrement())
  branchId      Int
  branch        Branch                  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  name          String
  phone         String?
  notes         String?
  /// Amount this team owes the pharmacy for stock taken on credit (AR).
  creditBalance Float                   @default(0)
  isActive      Boolean                 @default(true)
  members       OutreachTeamMember[]
  inventory     OutreachInventoryItem[]
  sales         Sale[]
  returns       OutreachReturn[]
  dispenses     OutreachDispense[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([branchId])
  @@map("outreach_teams")
}

model OutreachTeamMember {
  id        Int          @id @default(autoincrement())
  teamId    Int
  team      OutreachTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  role      String?
  createdAt DateTime     @default(now())

  @@index([teamId])
  @@map("outreach_team_members")
}

model OutreachInventoryItem {
  id        Int          @id @default(autoincrement())
  teamId    Int
  team      OutreachTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  productId Int
  product   Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int          @default(0)

  @@unique([teamId, productId])
  @@map("outreach_inventory_items")
}

model OutreachReturn {
  id          Int                  @id @default(autoincrement())
  teamId      Int
  team        OutreachTeam         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  branchId    Int
  branch      Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  returnDate  DateTime             @default(now())
  totalAmount Float                @default(0)
  notes       String?
  createdById Int?
  createdBy   User?                @relation("OutreachReturnCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items       OutreachReturnItem[]
  createdAt   DateTime             @default(now())

  @@index([teamId, returnDate])
  @@map("outreach_returns")
}

model OutreachReturnItem {
  id          Int            @id @default(autoincrement())
  returnId    Int
  return      OutreachReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity    Int
  unitPrice   Float
  totalAmount Float
  createdAt   DateTime       @default(now())

  @@map("outreach_return_items")
}

model OutreachDispense {
  id          Int                    @id @default(autoincrement())
  patientId   Int
  patient     Patient                @relation(fields: [patientId], references: [id], onDelete: Restrict)
  teamId      Int
  team        OutreachTeam           @relation(fields: [teamId], references: [id], onDelete: Restrict)
  branchId    Int
  branch      Branch                 @relation(fields: [branchId], references: [id], onDelete: Restrict)
  totalAmount Float
  notes       String?
  createdById Int?
  createdBy   User?                  @relation("OutreachDispenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items       OutreachDispenseItem[]
  createdAt   DateTime               @default(now())

  @@index([teamId, createdAt])
  @@map("outreach_dispenses")
}

model OutreachDispenseItem {
  id          Int              @id @default(autoincrement())
  dispenseId  Int
  dispense    OutreachDispense @relation(fields: [dispenseId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity    Int
  unitPrice   Float
  totalAmount Float
  createdAt   DateTime         @default(now())

  @@map("outreach_dispense_items")
}

model PatientPayment {
  id              Int                  @id @default(autoincrement())
  patientId       Int
  patient         Patient              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  /// Cash/collected amount posted to the linked finance account (deposit).
  amount          Float
  /// Discount/write-off applied toward the client balance on this transaction (no cash movement).
  discount        Float                @default(0)
  /// medication (appointment / visit charges) | prescription | pharmacy_credit | laboratory — laboratory may link to a lab order
  category        String               @default("medication")
  paymentMethodId Int?
  paymentMethod   LedgerPaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  /// When set, cash + discount settle this lab order fee (reception).
  labOrderId      Int?
  labOrder        LabOrder?            @relation(fields: [labOrderId], references: [id], onDelete: SetNull)
  careFileId      Int?
  careFile        PatientCareFile?     @relation(fields: [careFileId], references: [id], onDelete: SetNull)
  notes           String?
  createdById     Int?
  createdBy       User?                @relation("PatientPaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime             @default(now())

  @@index([patientId, createdAt])
  @@index([labOrderId])
  @@index([careFileId])
  @@map("patient_payments")
}

// --- Patient History (Doctor records) ---

model PatientHistory {
  id            Int              @id @default(autoincrement())
  patientId     Int
  patient       Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId Int?
  appointment   Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  doctorId      Int
  doctor        Doctor           @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  type          String // chief_complaint, history, examination, diagnosis, notes
  notes         String           @db.Text
  careFileId    Int?
  careFile      PatientCareFile? @relation(fields: [careFileId], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())

  @@index([careFileId])
  @@map("patient_histories")
}

// --- Lab ---

model LabCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  tests       LabTest[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("lab_categories")
}

model LabTest {
  id          Int                 @id @default(autoincrement())
  categoryId  Int
  category    LabCategory         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  /// When set, this test is a sub-test (child line) of a panel/root test. Only one level: parents have no parent.
  parentTestId Int?
  parentTest   LabTest?           @relation("LabTestSubtests", fields: [parentTestId], references: [id], onDelete: Restrict)
  subtests     LabTest[]          @relation("LabTestSubtests")
  name        String
  code        String?
  unit        String?
  normalRange String? // e.g. "70-100 mg/dL"
  /// Fee charged to the patient when this test is ordered (snapshot copied to order lines).
  price       Float               @default(0)
  isActive    Boolean             @default(true)
  orderItems  LabOrderItem[]
  orderItemsAsPanelParent LabOrderItem[] @relation("LabOrderItemPanelParent")
  disposables LabTestDisposable[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([parentTestId])
  @@map("lab_tests")
}

/// Lab inventory consumed when a lab test result is completed (matched by LabInventoryItem.code per branch).
model LabTestDisposable {
  id               Int      @id @default(autoincrement())
  labTestId        Int
  labTest          LabTest  @relation(fields: [labTestId], references: [id], onDelete: Cascade)
  /// Matched to LabInventoryItem.code at the appointment branch; one unit = one quantity step (label = item.unit).
  productCode      String
  /// Inventory units to deduct per completed test line, interpreted in `deductionUnitKey` (see LabInventoryUnit).
  unitsPerTest     Float
  /// Which LabInventoryUnit.unitKey this line uses (e.g. base, pair, box). Stock is stored in base units.
  deductionUnitKey String   @default("base")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([labTestId, productCode])
  @@index([labTestId])
  @@map("lab_test_disposables")
}

model LabOrder {
  id                   Int              @id @default(autoincrement())
  appointmentId        Int
  appointment          Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  patientId            Int
  patient              Patient          @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId             Int
  doctor               Doctor           @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  orderedById          Int?
  orderedBy            User?            @relation("LabOrderCreatedBy", fields: [orderedById], references: [id], onDelete: SetNull)
  status               String           @default("pending") // pending, completed, cancelled
  notes                String?
  /// Sum of line unit prices at order time (lab fee charged to patient account).
  totalAmount          Float            @default(0)
  /// Cash received at reception toward this order (see PatientPayment when linked).
  labFeePaidAmount     Float            @default(0)
  /// Discount/write-off applied at reception toward this order.
  labFeeDiscountAmount Float            @default(0)
  items                LabOrderItem[]
  patientPayments      PatientPayment[]
  careFileId           Int?
  careFile             PatientCareFile? @relation(fields: [careFileId], references: [id], onDelete: SetNull)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([careFileId])
  @@map("lab_orders")
}

model LabOrderItem {
  id                    Int                @id @default(autoincrement())
  labOrderId            Int
  labOrder              LabOrder           @relation(fields: [labOrderId], references: [id], onDelete: Cascade)
  labTestId             Int
  labTest               LabTest            @relation(fields: [labTestId], references: [id], onDelete: Restrict)
  /// When this line was created from a panel order, references the parent/panel test id (for grouping and print).
  panelParentTestId     Int?
  panelParentTest       LabTest?           @relation("LabOrderItemPanelParent", fields: [panelParentTestId], references: [id], onDelete: SetNull)
  /// Test fee at time of order (from LabTest.price).
  unitPrice             Float              @default(0)
  resultValue           String?            @db.Text
  resultUnit            String?
  status                String             @default("pending") // pending, completed
  recordedById          Int?
  recordedBy            User?              @relation("LabResultRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  recordedAt            DateTime?
  notes                 String?
  /// Set when inventory disposables for this line were deducted (idempotent).
  disposablesDeductedAt DateTime?
  createdAt             DateTime           @default(now())
  stockMovements        LabStockMovement[]

  @@index([panelParentTestId])
  @@map("lab_order_items")
}

/// Consumables and supplies held in the lab (separate from pharmacy Product stock).
model LabInventoryItem {
  id           Int                @id @default(autoincrement())
  branchId     Int
  branch       Branch             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  name         String
  code         String
  /// Label for the smallest stock step (same as LabInventoryUnit key "base").
  unit         String             @default("pcs")
  /// On-hand quantity in base (smallest) units — see LabInventoryUnit with unitKey "base".
  quantity     Int                @default(0)
  /// Lab POS price per stock unit; default 0 for fee-free issue/sale tracking.
  sellingPrice Float              @default(0)
  isActive     Boolean            @default(true)
  labUnits     LabInventoryUnit[]
  movements    LabStockMovement[]
  labSaleItems LabSaleItem[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([branchId, code])
  @@index([branchId])
  @@map("lab_inventory_items")
}

/// Alternate count units for the same lab line (e.g. 1 pair = 2 pcs base), like pharmacy ProductSaleUnit.
model LabInventoryUnit {
  id                 Int              @id @default(autoincrement())
  labInventoryItemId Int
  labInventoryItem   LabInventoryItem @relation(fields: [labInventoryItemId], references: [id], onDelete: Cascade)
  unitKey            String
  label              String
  /// One count of this unit equals this many base units (stock quantity steps).
  baseUnitsEach      Int
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([labInventoryItemId, unitKey])
  @@index([labInventoryItemId])
  @@map("lab_inventory_units")
}

/// Stock in/out for lab inventory (receipts, adjustments, test disposables, lab POS sales).
model LabStockMovement {
  id                 Int              @id @default(autoincrement())
  labInventoryItemId Int
  labInventoryItem   LabInventoryItem @relation(fields: [labInventoryItemId], references: [id], onDelete: Restrict)
  branchId           Int
  branch             Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  /// Positive = stock in; negative = stock out.
  signedQuantity     Int
  /// receive | adjustment | disposable | lab_sale
  reason             String
  labOrderItemId     Int?
  labOrderItem       LabOrderItem?    @relation(fields: [labOrderItemId], references: [id], onDelete: SetNull)
  labSaleId          Int?
  labSale            LabSale?         @relation(fields: [labSaleId], references: [id], onDelete: SetNull)
  notes              String?          @db.Text
  createdById        Int?
  createdBy          User?            @relation("LabStockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())

  @@index([branchId, createdAt])
  @@index([labInventoryItemId, createdAt])
  @@index([reason, createdAt])
  @@map("lab_stock_movements")
}

model LabSale {
  id             Int                @id @default(autoincrement())
  branchId       Int
  branch         Branch             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  saleDate       DateTime           @default(now())
  totalAmount    Float              @default(0)
  /// Optional when totalAmount is 0 (fee-free).
  paymentMethod  String             @default("")
  patientId      Int?
  patient        Patient?           @relation(fields: [patientId], references: [id], onDelete: SetNull)
  customerType   String             @default("walking")
  notes          String?
  createdById    Int?
  createdBy      User?              @relation("LabSaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items          LabSaleItem[]
  stockMovements LabStockMovement[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([branchId, saleDate])
  @@map("lab_sales")
}

model LabSaleItem {
  id                 Int              @id @default(autoincrement())
  labSaleId          Int
  labSale            LabSale          @relation(fields: [labSaleId], references: [id], onDelete: Cascade)
  labInventoryItemId Int
  labInventoryItem   LabInventoryItem @relation(fields: [labInventoryItemId], references: [id], onDelete: Restrict)
  quantity           Int
  unitPrice          Float
  totalAmount        Float

  @@index([labSaleId])
  @@map("lab_sale_items")
}

// --- Prescriptions (Doctor prescribes from inventory) ---

model Prescription {
  id            Int                @id @default(autoincrement())
  appointmentId Int
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  patientId     Int
  patient       Patient            @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId      Int
  doctor        Doctor             @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  createdById   Int?
  createdBy     User?              @relation("PrescriptionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  /// Urgent / home-visit style Rx (multiple allowed per patient; filter on Patient invoice).
  isEmergency   Boolean            @default(false)
  status        String             @default("pending") // pending, dispensed, cancelled
  notes         String?
  items         PrescriptionItem[]
  careFileId    Int?
  careFile      PatientCareFile?   @relation(fields: [careFileId], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([careFileId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             Int          @id @default(autoincrement())
  prescriptionId Int
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  productId      Int
  product        Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity       Int
  dosage         String? // e.g. "1 tablet twice daily"
  instructions   String?
  dispensedQty   Int?         @default(0) // how much was dispensed
  createdAt      DateTime     @default(now())

  @@map("prescription_items")
}

// --- Expenses ---

model ExpenseCategory {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  isActive  Boolean   @default(true)
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("expense_categories")
}

model Expense {
  id          Int             @id @default(autoincrement())
  categoryId  Int
  category    ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amount      Float
  expenseDate DateTime        @db.Date
  description String?
  createdById Int?
  createdBy   User?           @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("expenses")
}

// --- Finance: accounts, payment methods, ledger ---

model FinanceAccount {
  id             Int                   @id @default(autoincrement())
  name           String
  code           String?               @unique
  type           String                @default("cash") // cash, bank, mobile, other
  openingBalance Float                 @default(0)
  isActive       Boolean               @default(true)
  paymentMethods LedgerPaymentMethod[]
  transactions   AccountTransaction[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@map("finance_accounts")
}

model LedgerPaymentMethod {
  id               Int                  @id @default(autoincrement())
  name             String
  accountId        Int
  account          FinanceAccount       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  isActive         Boolean              @default(true)
  transactions     AccountTransaction[]
  purchases        Purchase[]
  patientPayments  PatientPayment[]
  doctorVisitCards DoctorVisitCard[]
  appointments     Appointment[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@map("ledger_payment_methods")
}

model AccountTransaction {
  id                Int                  @id @default(autoincrement())
  accountId         Int
  account           FinanceAccount       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  kind              String // deposit | withdrawal
  amount            Float
  description       String?
  saleId            Int?                 @unique
  sale              Sale?                @relation(fields: [saleId], references: [id], onDelete: SetNull)
  purchaseId        Int?                 @unique
  purchase          Purchase?            @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  paymentMethodId   Int?
  paymentMethod     LedgerPaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  transactionDate   DateTime             @default(now())
  createdById       Int?
  createdBy         User?                @relation("FinanceTransactionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  doctorVisitCardId Int?                 @unique
  doctorVisitCard   DoctorVisitCard?     @relation(fields: [doctorVisitCardId], references: [id], onDelete: SetNull)
  createdAt         DateTime             @default(now())

  @@index([accountId, transactionDate])
  @@map("account_transactions")
}

/// User activity and security audit trail (logins, mutations, key transactions).
model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       String
  module       String?
  resourceType String?
  resourceId   Int?
  metadata     Json?
  ipAddress    String?
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([module, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Admin-built forms (Google Forms–style builder). Field types are stored as strings; see app validation.
model CustomForm {
  id          Int                  @id @default(autoincrement())
  title       String
  description String?              @db.Text
  isPublished Boolean              @default(false)
  createdById Int?
  createdBy   User?                @relation("CustomFormCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  fields      CustomFormField[]
  responses   CustomFormResponse[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("custom_forms")
}

model CustomFormField {
  id          Int        @id @default(autoincrement())
  formId      Int
  form        CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  sortOrder   Int        @default(0)
  /// SHORT_TEXT | LONG_TEXT | EMAIL | NUMBER | DATE | CHECKBOX | RADIO | SELECT | MULTI_CHECK
  fieldType   String
  label       String
  placeholder String?
  helpText    String?    @db.Text
  required    Boolean    @default(false)
  /// JSON array of option labels for RADIO, SELECT, MULTI_CHECK
  options     Json?

  @@index([formId, sortOrder])
  @@map("custom_form_fields")
}

/// One filled instance of a custom form for a client (often linked to a booking).
model CustomFormResponse {
  id            Int                @id @default(autoincrement())
  formId        Int
  form          CustomForm         @relation(fields: [formId], references: [id], onDelete: Cascade)
  patientId     Int
  patient       Patient            @relation(fields: [patientId], references: [id], onDelete: Restrict)
  appointmentId Int?
  appointment   Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  submittedById Int?
  submittedBy   User?              @relation("CustomFormResponseSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  answers       CustomFormAnswer[]
  submittedAt   DateTime           @default(now())

  @@index([formId, submittedAt])
  @@index([patientId, submittedAt])
  @@index([appointmentId])
  @@map("custom_form_responses")
}

/// Answers store label/type snapshots so form definitions can change without breaking history.
model CustomFormAnswer {
  id         Int                @id @default(autoincrement())
  responseId Int
  response   CustomFormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  fieldId    Int
  fieldLabel String
  fieldType  String
  /// Plain text, JSON array for MULTI_CHECK, "1"/"0" for CHECKBOX
  value      String             @db.Text

  @@unique([responseId, fieldId])
  @@index([responseId])
  @@map("custom_form_answers")
}

/// HR staff record (not the same as system User login).
model StaffMember {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String
  address      String   @db.Text
  title        String
  cvUrl        String?
  cvPublicId   String?
  /// Profile photo (image upload, Cloudinary).
  photoUrl     String?
  photoPublicId String?
  hireDate     DateTime
  /// JSON array of weekday codes: mon, tue, wed, thu, fri, sat, sun
  workingDays  String   @db.Text
  /// e.g. "08:00 - 17:00"
  workingHours String
  salaryAmount Float?
  isActive     Boolean  @default(true)
  createdById  Int?
  createdBy    User?    @relation("StaffMemberCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([hireDate])
  @@index([isActive])
  @@map("staff_members")
}
